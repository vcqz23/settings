        if Settings.SilentAim.Checks.AliveCheck and not IsAlive(player) then continue end
        
        if Settings.SilentAim.Checks.VisibleCheck and not IsVisible(player) then continue end
        
        local targetPart = character:FindFirstChild(Settings.SilentAim.TargetPart)
        if not targetPart then continue end
        
        local screenPos, onScreen = WorldToScreen(targetPart.Position)
        if not onScreen then continue end
        
        local mousePos = UserInputService:GetMouseLocation()
        local distance = (screenPos - mousePos).Magnitude
        
        if distance < shortestDistance then
            shortestDistance = distance
            closestPlayer = player
        end
    end
    
    return closestPlayer
end

-- Main Loops
RunService.RenderStepped:Connect(function()
    -- Update FOV Circle
    if Settings.Aimbot.FOV.Visible and Settings.Aimbot.Enabled then
        FOVCircle.Visible = true
        FOVCircle.Radius = Settings.Aimbot.FOV.Radius
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Color = Settings.Aimbot.FOV.Color
        FOVCircle.Transparency = Settings.Aimbot.FOV.Transparency
        FOVCircle.Filled = Settings.Aimbot.FOV.Filled
    else
        FOVCircle.Visible = false
    end
    
    -- Update ESP
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            UpdateESP(player)
        end
    end
    
    -- Aimbot
    if Settings.Aimbot.Enabled and Settings.Aimbot.IsActive then
        local targetPlayer = GetClosestPlayerToMouse()
        if targetPlayer then
            local character = GetCharacter(targetPlayer)
            local targetPart = character and character:FindFirstChild(Settings.Aimbot.TargetPart)
            
            if targetPart then
                local targetPos = targetPart.Position
                
                -- Apply prediction
                if Settings.Aimbot.Prediction.Enabled then
                    local velocity = targetPart.AssemblyLinearVelocity
                    targetPos = targetPos + (velocity * Settings.Aimbot.Prediction.Amount)
                end
                
                -- Apply smoothing
                if Settings.Aimbot.Smoothing.Enabled then
                    local currentCFrame = Camera.CFrame
                    local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                    
                    if Settings.Aimbot.StickyAim.Enabled then
                        local currentLook = currentCFrame.LookVector
                        local targetLook = (targetPos - currentCFrame.Position).Unit
                        local smoothedLook = currentLook:Lerp(targetLook, Settings.Aimbot.StickyAim.Strength)
                        Camera.CFrame = CFrame.new(currentCFrame.Position, currentCFrame.Position + smoothedLook)
                    else
                        Camera.CFrame = currentCFrame:Lerp(targetCFrame, Settings.Aimbot.Smoothing.Amount)
                    end
                else
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                end
            end
        end
    end
end)

