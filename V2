-- Velocity Manipulation
RunService.Heartbeat:Connect(function()
    if not Settings.Velocity.Enabled then return end
    
    local character = GetCharacter(LocalPlayer)
    local rootPart = GetRootPart(character)
    if not rootPart then return end
    
    if Settings.Velocity.Method == "AssemblyLinearVelocity" then
        if Settings.Velocity.OnlyY then
            rootPart.AssemblyLinearVelocity = Vector3.new(
                rootPart.AssemblyLinearVelocity.X,
                Settings.Velocity.Amount.Y,
                rootPart.AssemblyLinearVelocity.Z
            )
        else
            rootPart.AssemblyLinearVelocity = Vector3.new(
                Settings.Velocity.Amount.X,
                Settings.Velocity.Amount.Y,
                Settings.Velocity.Amount.Z
            )
        end
    elseif Settings.Velocity.Method == "Velocity" then
        if Settings.Velocity.OnlyY then
            rootPart.Velocity = Vector3.new(
                rootPart.Velocity.X,
                Settings.Velocity.Amount.Y,
                rootPart.Velocity.Z
            )
        else
            rootPart.Velocity = Vector3.new(
                Settings.Velocity.Amount.X,
                Settings.Velocity.Amount.Y,
                Settings.Velocity.Amount.Z
            )
        end
    elseif Settings.Velocity.Method == "CFrame" then
        local moveDirection = Vector3.new(0, 0, 0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + (Camera.CFrame.LookVector * Settings.Velocity.CustomAmount)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection - (Camera.CFrame.LookVector * Settings.Velocity.CustomAmount)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection - (Camera.CFrame.RightVector * Settings.Velocity.CustomAmount)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + (Camera.CFrame.RightVector * Settings.Velocity.CustomAmount)
        end
        
        if moveDirection.Magnitude > 0 then
            rootPart.CFrame = rootPart.CFrame + (moveDirection * 0.01)
        end
    end
end)

