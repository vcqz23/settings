-- Silent Aim Hook (Fixed - No camera freeze)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if Settings.SilentAim.Enabled and not checkcaller() then
        if method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRay" or method == "Raycast" then
            -- Check hit chance
            if math.random(1, 100) <= Settings.SilentAim.HitChance then
                local targetPlayer = GetClosestPlayerForSilentAim()
                
                if targetPlayer then
                    local character = GetCharacter(targetPlayer)
                    local targetPart = character and character:FindFirstChild(Settings.SilentAim.TargetPart)
                    
                    if targetPart then
                        local targetPos = targetPart.Position
                        
                        -- Apply prediction
                        if Settings.SilentAim.Prediction.Enabled then
                            local velocity = targetPart.AssemblyLinearVelocity
                            targetPos = targetPos + (velocity * Settings.SilentAim.Prediction.Amount)
                        end
                        
                        -- Modify ray direction
                        if method == "Raycast" then
                            local origin = args[1]
                            args[2] = (targetPos - origin).Unit * 1000
                        else
                            local ray = args[1]
                            args[1] = Ray.new(ray.Origin, (targetPos - ray.Origin).Unit * 1000)
                        end
                    end
                end
            end
        end
    end
    
    return oldNamecall(self, unpack(args))
end))

