local function RemoveESP(player)
    if not ESPObjects[player] then return end
    
    local esp = ESPObjects[player]
    
    for _, line in pairs(esp.Box) do
        if typeof(line) == "table" and line.Remove then
            line:Remove()
        elseif typeof(line) ~= "table" then
            line:Remove()
        end
    end
    
    esp.Name:Remove()
    esp.Health.Text:Remove()
    esp.Health.Bar:Remove()
    esp.Health.BarOutline:Remove()
    esp.Distance:Remove()
    esp.Tracer:Remove()
    
    for _, line in ipairs(esp.Skeleton) do
        line:Remove()
    end
    
    ESPObjects[player] = nil
end

local function UpdateESP(player)
    if not ESPObjects[player] then return end
    
    local esp = ESPObjects[player]
    local character = GetCharacter(player)
    local rootPart = GetRootPart(character)
    local humanoid = GetHumanoid(character)
    
    if not character or not rootPart or not humanoid or humanoid.Health <= 0 then
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
        esp.Name.Visible = false
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
        esp.Distance.Visible = false
        esp.Tracer.Visible = false
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
        return
    end
    
    -- Team check
    if Settings.ESP.TeamCheck and player.Team == LocalPlayer.Team then
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
        esp.Name.Visible = false
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
        esp.Distance.Visible = false
        esp.Tracer.Visible = false
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
        return
    end
    
    -- Visible check
    if Settings.ESP.VisibleOnly and not IsVisible(player) then
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
        esp.Name.Visible = false
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
        esp.Distance.Visible = false
        esp.Tracer.Visible = false
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
        return
    end
    
    -- Distance check
    local distance = GetDistance(player)
    if distance > Settings.ESP.MaxDistance then
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
        esp.Name.Visible = false
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
        esp.Distance.Visible = false
        esp.Tracer.Visible = false
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
        return
    end
    
    -- Get color
    local color = Settings.ESP.Box.Color
    if Settings.ESP.TeamColor and player.Team then
        color = player.Team.TeamColor.Color
    end
    
    -- Calculate box corners (supporting both R6 and R15)
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    -- Detect R6 or R15
    local isR15 = character:FindFirstChild("UpperTorso") ~= nil
    
    -- Get the lowest point (feet)
    local lowestY = rootPart.Position.Y
    
    if isR15 then
        -- R15 Model
        local leftFoot = character:FindFirstChild("LeftFoot")
        local rightFoot = character:FindFirstChild("RightFoot")
        local leftLowerLeg = character:FindFirstChild("LeftLowerLeg")
        local rightLowerLeg = character:FindFirstChild("RightLowerLeg")
        
        if leftFoot then
            lowestY = math.min(lowestY, leftFoot.Position.Y - (leftFoot.Size.Y / 2))
        end
        if rightFoot then
            lowestY = math.min(lowestY, rightFoot.Position.Y - (rightFoot.Size.Y / 2))
        end
        if leftLowerLeg then
            lowestY = math.min(lowestY, leftLowerLeg.Position.Y - (leftLowerLeg.Size.Y / 2))
        end
        if rightLowerLeg then
            lowestY = math.min(lowestY, rightLowerLeg.Position.Y - (rightLowerLeg.Size.Y / 2))
        end
    else
        -- R6 Model
        local leftLeg = character:FindFirstChild("Left Leg")
        local rightLeg = character:FindFirstChild("Right Leg")
        
        if leftLeg then
            lowestY = math.min(lowestY, leftLeg.Position.Y - (leftLeg.Size.Y / 2))
        end
        if rightLeg then
            lowestY = math.min(lowestY, rightLeg.Position.Y - (rightLeg.Size.Y / 2))
        end
    end
    
    local hrpSize = rootPart.Size
    local headSize = head.Size
    
    local topY = head.Position.Y + (headSize.Y / 2)
    local bottomY = lowestY
    
    -- Increase width by 20% for better visibility
    local widthMultiplier = 1.2
    
    local corners = {
        Vector3.new(rootPart.Position.X + (hrpSize.X/2 * widthMultiplier), topY, rootPart.Position.Z + (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X - (hrpSize.X/2 * widthMultiplier), topY, rootPart.Position.Z + (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X - (hrpSize.X/2 * widthMultiplier), topY, rootPart.Position.Z - (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X + (hrpSize.X/2 * widthMultiplier), topY, rootPart.Position.Z - (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X + (hrpSize.X/2 * widthMultiplier), bottomY, rootPart.Position.Z + (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X - (hrpSize.X/2 * widthMultiplier), bottomY, rootPart.Position.Z + (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X - (hrpSize.X/2 * widthMultiplier), bottomY, rootPart.Position.Z - (hrpSize.Z/2 * widthMultiplier)),
        Vector3.new(rootPart.Position.X + (hrpSize.X/2 * widthMultiplier), bottomY, rootPart.Position.Z - (hrpSize.Z/2 * widthMultiplier))
    }
    
    local screenCorners = {}
    local allOnScreen = true
    
    for i, corner in ipairs(corners) do
        local screenPos, onScreen = WorldToScreen(corner)
        screenCorners[i] = screenPos
        if not onScreen then
            allOnScreen = false
        end
    end
    
    if not allOnScreen then
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
        esp.Name.Visible = false
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
        esp.Distance.Visible = false
        esp.Tracer.Visible = false
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
        return
    end
    
    -- Find min/max for 2D box
    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    
    for _, pos in ipairs(screenCorners) do
        minX = math.min(minX, pos.X)
        minY = math.min(minY, pos.Y)
        maxX = math.max(maxX, pos.X)
        maxY = math.max(maxY, pos.Y)
    end
    
    local boxWidth = maxX - minX
    local boxHeight = maxY - minY
    
    -- Update Box
    if Settings.ESP.Enabled and Settings.ESP.Box.Enabled then
        local thickness = Settings.ESP.Box.Thickness
        
        -- Corner lines
        local cornerSize = math.min(boxWidth, boxHeight) * 0.25
        
        -- Top left
        esp.Box.TopLeft.From = Vector2.new(minX, minY)
        esp.Box.TopLeft.To = Vector2.new(minX + cornerSize, minY)
        esp.Box.TopLeft.Color = color
        esp.Box.TopLeft.Thickness = thickness
        esp.Box.TopLeft.Visible = true
        
        -- Top right
        esp.Box.TopRight.From = Vector2.new(maxX, minY)
        esp.Box.TopRight.To = Vector2.new(maxX - cornerSize, minY)
        esp.Box.TopRight.Color = color
        esp.Box.TopRight.Thickness = thickness
        esp.Box.TopRight.Visible = true
        
        -- Bottom left
        esp.Box.BottomLeft.From = Vector2.new(minX, maxY)
        esp.Box.BottomLeft.To = Vector2.new(minX + cornerSize, maxY)
        esp.Box.BottomLeft.Color = color
        esp.Box.BottomLeft.Thickness = thickness
        esp.Box.BottomLeft.Visible = true
        
        -- Bottom right
        esp.Box.BottomRight.From = Vector2.new(maxX, maxY)
        esp.Box.BottomRight.To = Vector2.new(maxX - cornerSize, maxY)
        esp.Box.BottomRight.Color = color
        esp.Box.BottomRight.Thickness = thickness
        esp.Box.BottomRight.Visible = true
        
        -- Sides
        esp.Box.LeftSide.From = Vector2.new(minX, minY)
        esp.Box.LeftSide.To = Vector2.new(minX, minY + cornerSize)
        esp.Box.LeftSide.Color = color
        esp.Box.LeftSide.Thickness = thickness
        esp.Box.LeftSide.Visible = true
        
        esp.Box.RightSide.From = Vector2.new(maxX, minY)
        esp.Box.RightSide.To = Vector2.new(maxX, minY + cornerSize)
        esp.Box.RightSide.Color = color
        esp.Box.RightSide.Thickness = thickness
        esp.Box.RightSide.Visible = true
        
        esp.Box.TopSide.From = Vector2.new(minX, maxY)
        esp.Box.TopSide.To = Vector2.new(minX, maxY - cornerSize)
        esp.Box.TopSide.Color = color
        esp.Box.TopSide.Thickness = thickness
        esp.Box.TopSide.Visible = true
        
        esp.Box.BottomSide.From = Vector2.new(maxX, maxY)
        esp.Box.BottomSide.To = Vector2.new(maxX, maxY - cornerSize)
        esp.Box.BottomSide.Color = color
        esp.Box.BottomSide.Thickness = thickness
        esp.Box.BottomSide.Visible = true
        
        -- Filled box
        if Settings.ESP.Box.Filled then
            esp.Box.Filled.Size = Vector2.new(boxWidth, boxHeight)
            esp.Box.Filled.Position = Vector2.new(minX, minY)
            esp.Box.Filled.Color = color
            esp.Box.Filled.Transparency = Settings.ESP.Box.FilledTransparency
            esp.Box.Filled.Visible = true
        else
            esp.Box.Filled.Visible = false
        end
    else
        for _, line in pairs(esp.Box) do
            if typeof(line) ~= "table" then
                line.Visible = false
            end
        end
        esp.Box.Filled.Visible = false
    end
    
    -- Update Name
    if Settings.ESP.Enabled and Settings.ESP.Name.Enabled then
        esp.Name.Text = player.Name
        esp.Name.Position = Vector2.new(minX + boxWidth/2, minY - 18)
        esp.Name.Color = Settings.ESP.Name.Color
        esp.Name.Size = Settings.ESP.Name.Size
        esp.Name.Font = Settings.ESP.Name.Font
        esp.Name.Outline = Settings.ESP.Name.Outline
        esp.Name.Visible = true
    else
        esp.Name.Visible = false
    end
    
    -- Update Health
    if Settings.ESP.Enabled and Settings.ESP.Health.Enabled then
        local healthPercent = humanoid.Health / humanoid.MaxHealth
        
        if Settings.ESP.Health.ShowText then
            esp.Health.Text.Text = math.floor(humanoid.Health) .. " HP"
            esp.Health.Text.Position = Vector2.new(minX + boxWidth/2, minY - 4)
            esp.Health.Text.Color = Color3.fromRGB(255, 255, 255)
            esp.Health.Text.Size = Settings.ESP.Health.Size
            esp.Health.Text.Font = Settings.ESP.Health.Font
            esp.Health.Text.Visible = true
        else
            esp.Health.Text.Visible = false
        end
        
        if Settings.ESP.Health.ShowBar then
            local barHeight = boxHeight * healthPercent
            
            -- Outline (full height, black)
            esp.Health.BarOutline.From = Vector2.new(minX - 6, minY)
            esp.Health.BarOutline.To = Vector2.new(minX - 6, maxY)
            esp.Health.BarOutline.Thickness = Settings.ESP.Health.BarWidth + 2
            esp.Health.BarOutline.Color = Color3.new(0, 0, 0)
            esp.Health.BarOutline.Visible = true
            
            -- Health bar (green, from top, decreases downward as health decreases)
            esp.Health.Bar.From = Vector2.new(minX - 6, minY)
            esp.Health.Bar.To = Vector2.new(minX - 6, minY + barHeight)
            esp.Health.Bar.Thickness = Settings.ESP.Health.BarWidth
            esp.Health.Bar.Color = Color3.fromRGB(0, 255, 0)
            esp.Health.Bar.Visible = true
        else
            esp.Health.Bar.Visible = false
            esp.Health.BarOutline.Visible = false
        end
    else
        esp.Health.Text.Visible = false
        esp.Health.Bar.Visible = false
        esp.Health.BarOutline.Visible = false
    end
    
    -- Update Distance
    if Settings.ESP.Enabled and Settings.ESP.Distance.Enabled then
        local distText = math.floor(distance)
        if Settings.ESP.Distance.ShowMeters then
            distText = distText .. "m"
        end
        esp.Distance.Text = distText
        esp.Distance.Position = Vector2.new(minX + boxWidth/2, maxY + 4)
        esp.Distance.Color = Settings.ESP.Distance.Color
        esp.Distance.Size = Settings.ESP.Distance.Size
        esp.Distance.Font = Settings.ESP.Distance.Font
        esp.Distance.Visible = true
    else
        esp.Distance.Visible = false
    end
    
    -- Update Tracer
    if Settings.ESP.Enabled and Settings.ESP.Tracers.Enabled then
        local fromPos
        if Settings.ESP.Tracers.From == "Bottom" then
            fromPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        elseif Settings.ESP.Tracers.From == "Center" then
            fromPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        else
            fromPos = Vector2.new(Camera.ViewportSize.X / 2, 0)
        end
        
        esp.Tracer.From = fromPos
        esp.Tracer.To = Vector2.new(minX + boxWidth/2, maxY)
        esp.Tracer.Color = color
        esp.Tracer.Thickness = Settings.ESP.Tracers.Thickness
        esp.Tracer.Visible = true
    else
        esp.Tracer.Visible = false
    end
    
    -- Update Skeleton
    if Settings.ESP.Enabled and Settings.ESP.Skeleton.Enabled then
        local skeletonParts = {
            {"Head", "UpperTorso"},
            {"UpperTorso", "LowerTorso"},
            {"UpperTorso", "LeftUpperArm"},
            {"LeftUpperArm", "LeftLowerArm"},
            {"LeftLowerArm", "LeftHand"},
            {"UpperTorso", "RightUpperArm"},
            {"RightUpperArm", "RightLowerArm"},
            {"RightLowerArm", "RightHand"},
            {"LowerTorso", "LeftUpperLeg"},
            {"LeftUpperLeg", "LeftLowerLeg"},
            {"LeftLowerLeg", "LeftFoot"},
            {"LowerTorso", "RightUpperLeg"},
            {"RightUpperLeg", "RightLowerLeg"},
            {"RightLowerLeg", "RightFoot"}
        }
        
        for i, connection in ipairs(skeletonParts) do
            local part1 = character:FindFirstChild(connection[1])
            local part2 = character:FindFirstChild(connection[2])
            
            if part1 and part2 and esp.Skeleton[i] then
                local pos1, onScreen1 = WorldToScreen(part1.Position)
                local pos2, onScreen2 = WorldToScreen(part2.Position)
                
                if onScreen1 and onScreen2 then
                    esp.Skeleton[i].From = pos1
                    esp.Skeleton[i].To = pos2
                    esp.Skeleton[i].Color = Settings.ESP.Skeleton.Color
                    esp.Skeleton[i].Thickness = Settings.ESP.Skeleton.Thickness
                    esp.Skeleton[i].Visible = true
                else
                    esp.Skeleton[i].Visible = false
                end
            elseif esp.Skeleton[i] then
                esp.Skeleton[i].Visible = false
            end
        end
    else
        for _, line in ipairs(esp.Skeleton) do
            line.Visible = false
        end
    end
end

-- Aimbot Functions
local function GetClosestPlayerToMouse()
    local closestPlayer = nil
    local shortestDistance = Settings.Aimbot.FOV.Radius
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        if Settings.Aimbot.Checks.TeamCheck and player.Team == LocalPlayer.Team then continue end
        
        local character = GetCharacter(player)
        if not character then continue end
        
        if Settings.Aimbot.Checks.AliveCheck and not IsAlive(player) then continue end
        
        if Settings.Aimbot.Checks.ForceFieldCheck and HasForceField(character) then continue end
        
        if Settings.Aimbot.Checks.VisibleCheck and not IsVisible(player) then continue end
        
        local targetPart = character:FindFirstChild(Settings.Aimbot.TargetPart)
        if not targetPart then continue end
        
        local screenPos, onScreen = WorldToScreen(targetPart.Position)
        if not onScreen then continue end
        
        local mousePos = UserInputService:GetMouseLocation()
        local distance = (screenPos - mousePos).Magnitude
        
        if distance < shortestDistance then
            shortestDistance = distance
            closestPlayer = player
        end
    end
    
    return closestPlayer
end

-- Triggerbot Functions
local function GetPlayerAtCrosshair()
    local camera = Camera
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    
    -- Create ray from camera through screen center
    local ray = camera:ScreenPointToRay(screenCenter.X, screenCenter.Y)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, camera}
    raycastParams.IgnoreWater = true
    
    local result = Workspace:Raycast(ray.Origin, ray.Direction * Settings.Triggerbot.Range, raycastParams)
    
    if not result then return nil, nil end
    
    local hitPart = result.Instance
    local character = hitPart.Parent
    
    -- Check if hit part belongs to a player
    local player = Players:GetPlayerFromCharacter(character)
    if not player or player == LocalPlayer then return nil, nil end
    
    return player, hitPart
end

local function IsValidTriggerbotTarget(player, hitPart)
    if not player or not hitPart then return false end
    
    -- Team check
    if Settings.Triggerbot.Checks.TeamCheck and player.Team == LocalPlayer.Team then
        return false
    end
    
    -- Alive check
    if Settings.Triggerbot.Checks.AliveCheck and not IsAlive(player) then
        return false
    end
    
    -- ForceField check
    if Settings.Triggerbot.Checks.ForceFieldCheck and HasForceField(player.Character) then
        return false
    end
    
    -- Visibility check
    if Settings.Triggerbot.Checks.VisibleCheck and not IsVisible(player) then
        return false
    end
    
    -- Hitbox check - verify if hit part matches selected target part
    local partName = hitPart.Name
    if partName ~= Settings.Triggerbot.TargetPart then
        return false
    end
    
    return true
end

local function SimulateMouseClick()
    -- Simulate mouse click for shooting
    local VirtualInputManager = game:GetService("VirtualInputManager")
    
    -- Mouse button down
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
    
    -- Small delay
    wait(0.01)
    
    -- Mouse button up
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
end

local function CanShoot()
    local currentTime = tick() * 1000 -- Convert to milliseconds
    
    if not Settings.Triggerbot.Delay.Enabled then
        return true
    end
    
    local timeSinceLastShot = currentTime - Settings.Triggerbot.LastShot
    local minDelay = Settings.Triggerbot.Delay.Min
    local maxDelay = Settings.Triggerbot.Delay.Max
    
    -- Random delay between min and max
    local requiredDelay = math.random(minDelay, maxDelay)
    
    return timeSinceLastShot >= requiredDelay
end


-- Main Loops
RunService.RenderStepped:Connect(function()
    -- Update Aimbot FOV Circle
    if Settings.Aimbot.FOV.Visible and Settings.Aimbot.Enabled then
        FOVCircle.Visible = true
        FOVCircle.Radius = Settings.Aimbot.FOV.Radius
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Color = Settings.Aimbot.FOV.Color
        FOVCircle.Transparency = Settings.Aimbot.FOV.Transparency
        FOVCircle.Filled = Settings.Aimbot.FOV.Filled
    else
        FOVCircle.Visible = false
    end
    
    
    -- Update ESP
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            UpdateESP(player)
        end
    end
    
    -- Aimbot
    if Settings.Aimbot.Enabled and Options.AimbotKey:GetState() then
        local targetPlayer = nil
        
        -- Sticky Aim Logic - Lock onto target until disabled or target becomes invalid
        if Settings.Aimbot.StickyAim.Enabled and Settings.Aimbot.StickyAim.LockTarget then
            local lockedPlayer = Settings.Aimbot.StickyAim.LockTarget
            local character = GetCharacter(lockedPlayer)
            
            -- Check if locked target is still valid
            if character and IsAlive(lockedPlayer) and 
               (not Settings.Aimbot.Checks.TeamCheck or lockedPlayer.Team ~= LocalPlayer.Team) and
               (not Settings.Aimbot.Checks.VisibleCheck or IsVisible(lockedPlayer)) and
               (not Settings.Aimbot.Checks.ForceFieldCheck or not HasForceField(character)) then
                targetPlayer = lockedPlayer
            else
                -- Target became invalid, clear lock and find new target
                Settings.Aimbot.StickyAim.LockTarget = nil
                targetPlayer = GetClosestPlayerToMouse()
                if targetPlayer then
                    Settings.Aimbot.StickyAim.LockTarget = targetPlayer
                    Settings.Aimbot.StickyAim.LastSwitch = tick()
                end
            end
        else
            -- Normal aimbot or initial target acquisition
            targetPlayer = GetClosestPlayerToMouse()
            if targetPlayer and Settings.Aimbot.StickyAim.Enabled then
                local currentTime = tick()
                if currentTime - Settings.Aimbot.StickyAim.LastSwitch >= Settings.Aimbot.StickyAim.SwitchDelay then
                    Settings.Aimbot.StickyAim.LockTarget = targetPlayer
                    Settings.Aimbot.StickyAim.LastSwitch = currentTime
                end
            end
        end
        
        if targetPlayer then
            local character = GetCharacter(targetPlayer)
            local targetPart = character and character:FindFirstChild(Settings.Aimbot.TargetPart)
            
            if targetPart then
                local targetPos = targetPart.Position
                
                -- Apply prediction with separate X, Y, Z values
                if Settings.Aimbot.Prediction.Enabled then
                    local velocity = targetPart.AssemblyLinearVelocity
                    local predictionVector = Vector3.new(
                        velocity.X * Settings.Aimbot.Prediction.X,
                        velocity.Y * Settings.Aimbot.Prediction.Y,
                        velocity.Z * Settings.Aimbot.Prediction.Z
                    )
                    targetPos = targetPos + predictionVector
                end
                
                -- Apply smoothing
                if Settings.Aimbot.Smoothing.Enabled then
                    local currentCFrame = Camera.CFrame
                    local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                    Camera.CFrame = currentCFrame:Lerp(targetCFrame, Settings.Aimbot.Smoothing.Amount)
                else
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                end
            end
        end
    else
        if Settings.Aimbot.StickyAim.LockTarget then
            Settings.Aimbot.StickyAim.LockTarget = nil
        end
    end
    
    -- Triggerbot
    if Settings.Triggerbot.Enabled then
        local targetPlayer, hitPart = GetPlayerAtCrosshair()
        
        if targetPlayer and hitPart and IsValidTriggerbotTarget(targetPlayer, hitPart) then
            if CanShoot() then
                SimulateMouseClick()
                Settings.Triggerbot.LastShot = tick() * 1000 -- Update last shot time
            end
        end
    end
end)



